{
  "name": "workspace-doc-browser",
  "displayName": "Workspace Doc Browser",
  "description": "Open the current workspace as a live browser preview for Markdown-heavy repos.",
  "version": "0.0.1",
  "publisher": "redcreen",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:redcreen.workspaceDocBrowser.open"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "redcreen.workspaceDocBrowser.open",
        "title": "Use Browser Preview",
        "category": "Workspace Docs",
        "icon": "$(globe)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "redcreen.workspaceDocBrowser.open",
          "when": "editorLangId == markdown",
          "group": "navigation@9"
        }
      ],
      "explorer/context": [
        {
          "command": "redcreen.workspaceDocBrowser.open",
          "when": "resourceExtname == .md",
          "group": "navigation@9"
        }
      ],
      "editor/title/context": [
        {
          "command": "redcreen.workspaceDocBrowser.open",
          "when": "resourceExtname == .md || editorLangId == markdown",
          "group": "navigation@9"
        }
      ]
    }
  }
}
